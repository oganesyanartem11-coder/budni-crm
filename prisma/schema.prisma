// Prisma schema для CRM "Будни" — B2B-доставка еды
// Документация бизнес-логики см. в README.md (будет создан позже)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN_PRO
  ADMIN
  MANAGER
  CHEF
  COURIER
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum OrderType {
  DYNAMIC // Каждый день меняется, требует подтверждения до cut-off
  FIXED // Постоянное число, автогенерация
}

enum DeliveryHorizon {
  NEXT_DAY // Заказ сегодня → доставка завтра (типичный случай)
  SAME_DAY // Заказ утром → доставка в обед того же дня
}

enum ScheduleType {
  DAILY // Каждый день
  WEEKDAYS // Пн-Пт
  WEEKENDS // Сб-Вс
  CUSTOM_DAYS // Конкретные дни недели (см. scheduleData.daysOfWeek)
  ONE_TIME // Разовый, на конкретные даты (см. scheduleData.dates)
  INTERVAL // С интервалом или по датам месяца (см. scheduleData)
}

enum PackagingType {
  INDIVIDUAL // По 1 порции в индивидуальной таре
  BULK // В коробках по типам (супы отдельно, горячее отдельно)
}

enum OrderStatus {
  DRAFT // Черновик (создан, но не сохранён окончательно)
  PENDING_CONFIRMATION // Ждём подтверждения (динамика, до 16:00)
  CONFIRMED // Подтверждён, будет производиться
  LOCKED // Залочен после 18:00, изменения только админом
  IN_PRODUCTION // На производстве
  OUT_FOR_DELIVERY // В доставке
  DELIVERED // Доставлен
  CANCELLED // Отменён
}

enum OrderSource {
  MANUAL // Вручную через UI
  MESSENGER // Из мессенджера (после AI-парсинга, legacy)
  BOT // Из MAX-бота (Спринт 5.3+, через BotConversation)
  FIXED_AUTO // Автоматически сгенерирован для FIXED-конфига
  RECURRING_AUTO // Из расписания
}

enum DeliveryType {
  IN_HOUSE // Свой курьер
  EXTERNAL_COURIER // Внешний (Яндекс/Достависта/etc)
}

enum DeliveryStatus {
  ASSIGNED // Назначен курьер
  PICKED_UP // Забрал с производства
  EN_ROUTE // В пути
  DELIVERED // Доставлено
  FAILED // Не доставлено (с комментарием)
}

enum DishCategory {
  SOUP // Суп
  MAIN // Горячее блюдо
  GARNISH // Гарнир
  SALAD // Салат
  DESSERT // Десерт
  DRINK // Компот / напиток
  BREAD_WHITE // Белый хлеб
  BREAD_DARK // Чёрный хлеб
  PORRIDGE // Каша (завтрак)
  EGGS // Яйца / омлет (завтрак)
  PANCAKE // Блинчики (ужин)
  OTHER // Прочее
}

enum IngredientUnit {
  KG
  L
  PCS
}

enum DishUnit {
  PORTION // На порцию
  LITER // На литр (для супов, компотов)
  KG // На кг (для гарниров, салатов)
  PIECE // Поштучно (хлеб, блинчики)
}

enum MenuStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ARCHIVED
}

enum DishStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ARCHIVED
}

enum MenuImportSource {
  PHOTO
  EXCEL
}

enum MenuImportProgress {
  EXTRACTING // чтение файла (Excel/Vision)
  PARSING_SCHEDULE // LLM-распознавание меню (8.3)
  GENERATING_RECIPES // LLM-генерация техкарт (8.4)
  ASSEMBLING // запись в БД (8.5b)
  READY // импорт завершён, готов к ревью шефа
  FAILED // упало на каком-то этапе (см. reason)
}

enum LegalEntityType {
  INDIVIDUAL_ENTREPRENEUR
  LLC
}

// ============================================================
// INVOICES (Спринт 7.14A) — приёмка накладных с Vision-распознаванием
// ============================================================

enum IngredientStatus {
  DRAFT
  APPROVED
}

enum InvoiceStatus {
  PROCESSING
  AWAITING_ACCEPT
  ACCEPTED
  REJECTED
  REVERTED
  FAILED
}

enum InvoiceProgress {
  UPLOADED
  RECOGNIZING
  MATCHING
  READY
  FAILED
}

enum InvoiceMatchAction {
  MATCHED_EXISTING
  CREATED_NEW
  SKIPPED
}

enum InvoiceConfidence {
  HIGH
  MEDIUM
  LOW
}

enum PriceChangeLevel {
  LOW
  MEDIUM
  HIGH
  NEW
}

enum VatMode {
  NONE
  VAT_10_INCLUSIVE
}

// ============================================================
// USERS / AUTH
// ============================================================

model User {
  id                  String    @id @default(cuid())
  name                String
  role                UserRole
  pinHash             String    @unique // Хэш PIN-кода (bcrypt)
  // 7.11: HMAC-SHA256(JWT_SECRET, pin)[:16] — O(1)-индекс для логина,
  // bcrypt.compare остаётся как primary verify. Nullable, чтобы старые юзеры
  // заполнялись лениво при следующем успешном логине (см. login/actions.ts).
  pinLookupHash       String?   @unique
  isActive            Boolean   @default(true)
  lastLoginAt         DateTime?
  // 7.9: brute-force защита и ручная блокировка ADMIN'ом
  failedLoginAttempts Int       @default(0)
  loginLockedUntil    DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // MAX-онбординг для менеджера (Спринт 5.5+5.6) — оставлены для legacy токенов;
  // личный chat дропнут в 6.8a (пуши менеджерам идут через Telegram).
  maxOnboardingToken String?   @unique
  onboardedAt        DateTime?

  // Telegram-бот: миграция пушей и сводок с MAX на Telegram (Спринт 5.8+)
  telegramChatId              String?   @unique
  telegramUsername            String?
  telegramOnboardingToken     String?   @unique
  telegramOnboardingExpiresAt DateTime?

  // 7.15 hotfix #1: получатель критичных tone-алёртов (rude/urgent) сверх
  // дефолтного списка MANAGER. Включается явно — позволяет добавлять
  // конкретных ADMIN_PRO/ADMIN/CHEF без расширения ролевой логики.
  receivesToneAlerts Boolean @default(false)

  approvedMenus         MenuCycle[]   @relation("MenuApprovedBy")
  activityLogs          ActivityLog[]
  ordersCreated         Order[]       @relation("OrdersCreated")
  resolvedInboxItems    InboxItem[]
  generatedUpdDocuments UpdDocument[] @relation("UpdGeneratedBy")
  menuImports           MenuImport[]  @relation("MenuImportCreatedBy")
  approvedMenuImports   MenuImport[]  @relation("MenuImportApprovedBy")
  sessions              Session[]

  // 7.14A: приёмка накладных. receivedBy — кто загрузил фото (любая роль,
  // на практике ADMIN_PRO), acceptedBy — кто подтвердил (только ADMIN_PRO),
  // revertedBy — кто откатил приёмку (только ADMIN_PRO).
  invoicesReceived Invoice[] @relation("InvoicesReceived")
  invoicesAccepted Invoice[] @relation("InvoicesAccepted")
  invoicesReverted Invoice[] @relation("InvoicesReverted")

  @@index([role, isActive])
}

// 7.10: server-side sessions с возможностью revoke.
// JWT хранит только sessionId; реальная проверка revokedAt/expiresAt идёт
// в getCurrentUser. Cleanup через cron cleanup-sessions раз в неделю.
model Session {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  lastUsedAt DateTime  @default(now())
  ipAddress  String?
  userAgent  String?

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

// 7.9: глобальный rate-limit логина. Append-only, очищается еженедельно
// через cron cleanup-login-attempts (retention 30 дней).
model LoginAttempt {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  success   Boolean
  ipAddress String?

  @@index([createdAt, success])
}

// ============================================================
// CLIENTS
// ============================================================

model Client {
  id               String   @id @default(cuid())
  name             String
  contactName      String?
  contactPhone     String?
  contactMessenger String? // Username/ID в мессенджере
  notes            String? // Свободное поле о клиенте
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Бот-ассистент в MAX (Спринт 5)
  maxChatId          String? @unique
  maxUsername        String? // username в MAX, для deeplink «https://max.ru/<username>»
  maxOnboardingToken String? @unique
  locationAliases    Json? // {"loc_001": ["первый", "цех", "производство"]}
  safeAnswerStreak   Int     @default(0)

  // === Юридические реквизиты (Спринт 7b, опционально) ===
  legalName    String? // Полное юридическое название (для УПД)
  inn          String?
  kpp          String?
  ogrn         String?
  legalAddress String?

  // === Банковские реквизиты клиента (опционально) ===
  bankName        String?
  bankBic         String?
  bankAccount     String?
  bankCorrAccount String?

  // === Договор (опционально) ===
  contractNumber String?
  contractDate   DateTime? @db.Date

  // === Наше юрлицо для отгрузки (опционально, обязательно если есть inn) ===
  defaultOurLegalEntityId String?
  defaultOurLegalEntity   OurLegalEntity? @relation("ClientDefaultLegalEntity", fields: [defaultOurLegalEntityId], references: [id], onDelete: SetNull)

  locations        ClientLocation[]
  mealConfigs      ClientMealConfig[]
  orders           Order[]
  botConversations BotConversation[]
  botMessages      BotMessage[]
  inboxItems       InboxItem[]
  updDocuments     UpdDocument[]
  toneAlerts       ToneAlertLog[]
  clientAlerts     ClientAlertLog[]

  @@index([isActive])
  @@index([name])
  @@index([defaultOurLegalEntityId])
}

model ClientLocation {
  id                 String        @id @default(cuid())
  clientId           String
  client             Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name               String // Например, "Офис на Ленина" или "Стройка №3"
  address            String
  deliveryWindowFrom String? // Формат "HH:mm", например "11:30"
  deliveryWindowTo   String? // Формат "HH:mm", например "12:00"
  packaging          PackagingType @default(INDIVIDUAL)
  tags               String[]      @default([]) // Свободные пометки: "аллергия на цитрус", "без лука"
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  mealConfigs  ClientMealConfig[]
  orders       Order[]
  updDocuments UpdDocument[]

  @@index([clientId, isActive])
}

// Конфигурация питания клиента/точки: что заказывает, по какому графику, по какой цене
model ClientMealConfig {
  id              String          @id @default(cuid())
  clientId        String
  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  locationId      String // 6.8a: NOT NULL — конфиг всегда привязан к конкретной точке клиента
  location        ClientLocation  @relation(fields: [locationId], references: [id], onDelete: Cascade)
  mealType        MealType
  orderType       OrderType
  deliveryHorizon DeliveryHorizon @default(NEXT_DAY)
  scheduleType    ScheduleType
  scheduleData    Json? // Гибкие правила: {daysOfWeek: [1,2,3], dates: [...], intervalDays: 14}
  fixedPortions   Int? // Если orderType = FIXED
  pricePerPortion Decimal         @db.Decimal(10, 2)
  validFrom       DateTime        @default(now())
  validTo         DateTime? // Null = бессрочно
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  orders Order[]

  @@index([clientId, isActive])
  @@index([locationId])
  @@index([mealType, orderType])
}

// ============================================================
// INGREDIENTS / DISHES / TECH CARDS
// ============================================================

model Ingredient {
  id           String         @id @default(cuid())
  name         String         @unique
  unit         IngredientUnit
  pricePerUnit Decimal        @db.Decimal(10, 2) // Текущая цена за единицу
  notes        String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // 7.14A: DRAFT — создан Vision-импортом, ждёт ручного APPROVED от ADMIN_PRO.
  // APPROVED — нормальный ингредиент, виден в выпадашках, участвует в техкартах.
  // Дефолт APPROVED, чтобы существующие ингредиенты не сломались миграцией.
  status        IngredientStatus @default(APPROVED)
  // 7.14A: помечает овощи/фрукты — у них допустима бо́льшая волатильность цены,
  // поэтому пороги алёртов мягче. См. invoice-recognizer.
  isVegetable   Boolean          @default(false)
  // 7.14A: накопленные синонимы бренда / упаковки из распознанных накладных
  // ({"variant": "..", "supplier": "..", "seenAt": "..."} — массив).
  brandVariants Json?

  dishIngredients DishIngredient[]
  priceHistory    IngredientPriceHistory[]
  invoiceLines    InvoiceLine[]

  @@index([isActive])
}

// История изменений цен на ингредиенты
model IngredientPriceHistory {
  id           String     @id @default(cuid())
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  price        Decimal    @db.Decimal(10, 2)
  validFrom    DateTime   @default(now())
  changedBy    String? // user id

  @@index([ingredientId, validFrom])
}

model Dish {
  id          String       @id @default(cuid())
  name        String
  category    DishCategory
  unit        DishUnit     @default(PORTION)
  portionSize Int? // Размер порции в граммах/мл (для информации)
  notes       String?
  isActive    Boolean      @default(true)
  status      DishStatus   @default(APPROVED)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // AI-помощник шефа (Спринт 8): originalName — ключ связи с расписанием,
  // correctedName — что показывать; correctionLevel/Note — прозрачность правок.
  // Всё nullable — для блюд, созданных вне AI-импорта, эти поля не заполняются.
  originalName    String?
  correctedName   String?
  correctionLevel String?
  correctionNote  String?
  menuImportId    String?
  menuImport      MenuImport? @relation(fields: [menuImportId], references: [id])

  ingredients   DishIngredient[]
  menuDayDishes MenuDayDish[]

  @@index([category, isActive])
}

// Технологическая карта: ингредиенты в составе блюда (на 1 базовую единицу dish.unit)
model DishIngredient {
  id           String     @id @default(cuid())
  dishId       String
  dish         Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredientId String
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])
  bruttoGrams  Decimal    @db.Decimal(10, 2) // Сырой вес (для закупа)
  nettoGrams   Decimal    @db.Decimal(10, 2) // Чистый вес (для расчёта выхода)
  notes        String?

  @@unique([dishId, ingredientId])
  @@index([dishId])
}

// ============================================================
// MEAL SETS (типовые наборы: обед/ужин/завтрак)
// ============================================================

model MealSet {
  id        String   @id @default(cuid())
  mealType  MealType
  name      String // "Обед стандарт", "Ужин стандарт", "Завтрак стандарт"
  isDefault Boolean  @default(false) // true для базового набора каждого типа
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items    MealSetItem[]
  menuDays MenuDay[]

  @@index([mealType, isActive])
}

// Состав набора: какие категории блюд и в каком количестве (например, 1 суп, 2 белых хлеба)
model MealSetItem {
  id           String       @id @default(cuid())
  mealSetId    String
  mealSet      MealSet      @relation(fields: [mealSetId], references: [id], onDelete: Cascade)
  dishCategory DishCategory
  quantity     Int          @default(1) // Сколько штук этой категории в наборе

  @@index([mealSetId])
}

// ============================================================
// MENU CYCLE (недельное меню)
// ============================================================

model MenuCycle {
  id               String     @id @default(cuid())
  name             String // "Меню на неделю 17 (5-11 мая)"
  validFrom        DateTime // Начало недели (понедельник)
  validTo          DateTime // Конец недели (воскресенье)
  status           MenuStatus @default(DRAFT)
  approvedById     String?
  approvedBy       User?      @relation("MenuApprovedBy", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  rejectionComment String? // Комментарий от ADMIN при возврате на доработку
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  // 8.7: цикл, порождённый разворотом одобренного импорта (chefs approve → expand 13 weeks).
  // Отделено от legacy MenuImport.menuCycleId одиночного указателя — здесь обратная сторона
  // множественная: один MenuImport порождает 13+ MenuCycle.
  menuImportId String?
  menuImport   MenuImport? @relation("MenuCycleFromImport", fields: [menuImportId], references: [id])

  days        MenuDay[]
  menuImports MenuImport[]

  // 7.6 B.2: на одну неделю — ровно один цикл (любого статуса).
  @@unique([validFrom])
  @@index([validFrom, validTo])
  @@index([status])
  @@index([menuImportId])
}

model MenuDay {
  id          String    @id @default(cuid())
  menuCycleId String
  menuCycle   MenuCycle @relation(fields: [menuCycleId], references: [id], onDelete: Cascade)
  dayOfWeek   Int // 1 = Пн, 7 = Вс (ISO 8601)
  mealType    MealType
  mealSetId   String?
  mealSet     MealSet?  @relation(fields: [mealSetId], references: [id])

  dishes MenuDayDish[]

  @@unique([menuCycleId, dayOfWeek, mealType])
  @@index([menuCycleId])
}

// Конкретные блюда на этот день в этом типе питания
model MenuDayDish {
  id           String       @id @default(cuid())
  menuDayId    String
  menuDay      MenuDay      @relation(fields: [menuDayId], references: [id], onDelete: Cascade)
  dishId       String
  dish         Dish         @relation(fields: [dishId], references: [id])
  slotCategory DishCategory // Какой слот в наборе закрывает (суп, горячее...)

  @@index([menuDayId])
  @@index([dishId])
}

// Источник загрузки меню AI-помощником шефа (фото или Excel).
// Хранит сырой текст для аудита и возможной перегенерации, плюс созданные блюда.
model MenuImport {
  id               String             @id @default(cuid())
  source           MenuImportSource
  status           MenuStatus         @default(DRAFT)
  progress         MenuImportProgress @default(EXTRACTING)
  rawText          String // сырой дамп Excel / OCR фото — для аудита и перегенерации
  confidence       Float?
  reason           String?
  errorMessage     String?
  approvedById     String?
  approvedBy       User?              @relation("MenuImportApprovedBy", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  rejectionComment String?
  startDate        DateTime?
  createdById      String?
  createdBy        User?              @relation("MenuImportCreatedBy", fields: [createdById], references: [id])
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  dishes      Dish[]
  menuCycleId String?
  menuCycle   MenuCycle?  @relation(fields: [menuCycleId], references: [id])
  // 8.7: множественная связь — один импорт → 13+ MenuCycle при approve+expand.
  // Отдельное relation-имя, чтобы не путать с legacy одиночным menuCycleId выше.
  menuCycles  MenuCycle[] @relation("MenuCycleFromImport")

  @@index([status])
}

// ============================================================
// ORDERS
// ============================================================

model Order {
  id                String         @id @default(cuid())
  clientId          String
  client            Client         @relation(fields: [clientId], references: [id])
  locationId        String
  location          ClientLocation @relation(fields: [locationId], references: [id])
  mealType          MealType
  deliveryDate      DateTime       @db.Date
  status            OrderStatus    @default(DRAFT)
  portions          Int
  pricePerPortion   Decimal        @db.Decimal(10, 2) // Зафиксирована на момент создания
  totalPrice        Decimal        @db.Decimal(10, 2) // = portions * pricePerPortion
  packaging         PackagingType
  tags              String[]       @default([]) // Унаследованы от точки + добавочные на конкретный заказ
  source            OrderSource
  originalMessage   String? // Если из мессенджера — сырой текст
  notes             String?
  createdAt         DateTime       @default(now())
  confirmedAt       DateTime?
  lockedAt          DateTime?
  editedAfterLockAt DateTime?
  updatedAt         DateTime       @updatedAt

  // Аудит и связи с источником
  sourceConfigId String?
  sourceConfig   ClientMealConfig? @relation(fields: [sourceConfigId], references: [id], onDelete: SetNull)

  createdById String?
  createdBy   User?   @relation("OrdersCreated", fields: [createdById], references: [id], onDelete: SetNull)

  // Бот-источник заказа (Спринт 5.3+)
  sourceConversationId String?
  sourceConversation   BotConversation? @relation(fields: [sourceConversationId], references: [id], onDelete: SetNull)

  delivery Delivery?

  // 6.4: антидубль для cron'а check-late-deliveries.
  // Ставится при отправке алёрта в групповой Telegram (опоздание > 30 мин).
  lateAlertSentAt DateTime?

  // 7b-2: snapshot нашего юрлица отгрузки и ставки НДС на момент создания заказа.
  // Копируется из client.defaultOurLegalEntityId. Меняется отдельным action'ом
  // changeOrderLegalEntity (только до lock). Используется в УПД (7c).
  ourLegalEntityId String?
  ourLegalEntity   OurLegalEntity? @relation(fields: [ourLegalEntityId], references: [id], onDelete: SetNull)
  vatRate          Decimal?        @db.Decimal(5, 2)

  updDocumentLink UpdDocumentOrder?

  @@index([deliveryDate, status])
  @@index([clientId, deliveryDate])
  @@index([locationId, deliveryDate])
  @@index([status])
  @@index([ourLegalEntityId])
}

// ============================================================
// DELIVERY (упрощённо для MVP)
// ============================================================

model Delivery {
  id          String         @id @default(cuid())
  orderId     String         @unique
  order       Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type        DeliveryType
  courierName String? // Имя курьера (свой) или название службы
  status      DeliveryStatus @default(ASSIGNED)
  notes       String?
  pickedUpAt  DateTime?
  deliveredAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // 6.7: курьер сообщает «не смог доставить» с причиной из enum-like-набора
  // (ADDRESS_WRONG / CLIENT_UNAVAILABLE / ACCESS_DENIED / WEATHER / OTHER).
  // Статус Order не меняется — менеджер видит метку и решает что делать.
  // issueReportedById — id курьера (User.id) для аудита, без relation чтобы
  // не лезть в User-модель.
  issueReportedAt   DateTime?
  issueReason       String?
  issueComment      String?
  issueReportedById String?

  @@index([status])
  @@index([issueReportedAt])
}

// ============================================================
// SETTINGS / LOG
// ============================================================

// Глобальные настройки системы (key-value)
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// Лог действий (для аудита)
model ActivityLog {
  id         String    @id @default(cuid())
  userId     String?
  user       User?     @relation(fields: [userId], references: [id])
  userRole   UserRole?
  action     String // "ORDER_CREATED", "MENU_APPROVED", etc.
  entityType String? // "Order", "Client", "Menu"
  entityId   String?
  payload    Json? // Дополнительные данные
  createdAt  DateTime  @default(now())

  @@index([createdAt])
  @@index([entityType, entityId])
}

// 7.12: in-house Sentry-аналог. Дедуп по fingerprint = SHA-256(message + stackTop + url)[:16].
// В development НЕ пишется (см. src/lib/errors/tracker.ts). Чистится в cleanup-activity-log
// cron (см. 7.12 cleanup): resolved старше 30 дней удаляются.
model ErrorLog {
  id          String    @id @default(cuid())
  fingerprint String // SHA-256(message + stack-top-line + url)[:16]
  message     String
  stack       String?   @db.Text
  url         String?
  method      String?
  userId      String?
  userRole    String?
  environment String
  level       String    @default("error")
  count       Int       @default(1)
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  resolvedAt  DateTime?
  resolvedBy  String?
  payload     Json?

  @@unique([fingerprint])
  @@index([resolvedAt, lastSeenAt])
  @@index([lastSeenAt])
}

// ============================================================
// BOT ASSISTANT (Спринт 5)
// ============================================================

enum BotConversationStatus {
  PENDING
  AWAITING_MANAGER
  CONFIRMED
  EXPIRED
  CANCELLED
}

enum BotMessageDirection {
  IN
  OUT
  MANAGER_OUT
}

enum InboxItemReason {
  NEW_CLIENT
  ANOMALY_HISTORICAL
  ANOMALY_THRESHOLD
  ANOMALY_LLM_CONFIDENCE
  NON_NUMERIC
  CANCELLATION_INTENT
  POST_CUTOFF
}

enum InboxItemPriority {
  NORMAL
  HIGH
}

enum InboxItemStatus {
  UNREAD
  READ
}

model BotConversation {
  id              String                @id @default(cuid())
  client          Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId        String
  deliveryDate    DateTime
  status          BotConversationStatus @default(PENDING)
  questionVariant String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  messages   BotMessage[]
  inboxItems InboxItem[]
  orders     Order[]

  @@unique([clientId, deliveryDate])
  @@index([deliveryDate])
  @@index([status])
}

model BotMessage {
  id             String              @id @default(cuid())
  clientId       String
  client         Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversation   BotConversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  conversationId String?
  direction      BotMessageDirection
  text           String              @db.Text
  parsedJson     Json?
  llmConfidence  Float?
  llmReason      String?             @db.Text
  toneLabel      String?
  readAt         DateTime? // null = непрочитано (для IN-сообщений). Для OUT/MANAGER_OUT всегда null.
  createdAt      DateTime            @default(now())

  @@index([conversationId, createdAt])
  @@index([clientId, createdAt])
  @@index([direction, readAt])
}

model InboxItem {
  id                  String            @id @default(cuid())
  clientId            String
  client              Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  conversation        BotConversation?  @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  conversationId      String?
  reason              InboxItemReason
  priority            InboxItemPriority @default(NORMAL)
  status              InboxItemStatus   @default(UNREAD)
  humanReason         String?           @db.Text
  clientMessage       String?           @db.Text
  parsedJson          Json?
  clientStatsSnapshot Json?
  draftReply          String?           @db.Text
  managerReply        String?           @db.Text
  resolvedBy          User?             @relation(fields: [resolvedById], references: [id])
  resolvedById        String?
  createdAt           DateTime          @default(now())
  resolvedAt          DateTime?
  lastPushedAt        DateTime? // когда последний раз пушили менеджерам в MAX
  alerts              ClientAlertLog[]

  @@index([status, createdAt])
  @@index([priority, status])
  @@index([conversationId])
  @@index([clientId, status])
}

// ============================================================
// OUR LEGAL ENTITIES (Спринт 7)
// Наши юрлица для отгрузки. Используется в УПД (7c).
// ============================================================

model OurLegalEntity {
  id String @id @default(cuid())

  shortName String // "ИП Акопов"
  fullName  String // "Индивидуальный предприниматель Акопов Олег Армаисович"

  entityType LegalEntityType

  inn  String  @unique
  kpp  String?
  ogrn String  @unique // ОГРНИП у ИП (15 цифр), ОГРН у ООО (13 цифр)

  legalAddress String

  phone String?
  email String?

  bankName        String
  bankBic         String
  bankAccount     String
  bankCorrAccount String

  directorName     String
  directorPosition String @default("Директор")

  vatMode VatMode  @default(NONE)
  vatRate Decimal? @db.Decimal(5, 2)

  // Счётчик документов УПД с ресетом 1 января. Заполняется в Спринте 7c.
  lastDocumentNumber Int @default(0)
  lastDocumentYear   Int @default(0)

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultForClients Client[]      @relation("ClientDefaultLegalEntity")
  orders            Order[]
  updDocuments      UpdDocument[]

  @@index([isActive])
}

// ============================================================
// UPD DOCUMENTS (Спринт 7c)
// УПД — универсальный передаточный документ. Одна УПД = одна отгрузка
// в один день одной точке от одного юрлица (бизнес-ключ:
// ourLegalEntityId+clientId+locationId+deliveryDate).
// Может объединять несколько Order разных mealType (M2M через UpdDocumentOrder).
// Реквизиты замораживаются в snapshot-полях на момент создания.
// ============================================================

model UpdDocument {
  id             String @id @default(cuid())
  number         Int
  year           Int
  documentNumber String // "УПД-2026-0001"

  ourLegalEntityId String
  ourLegalEntity   OurLegalEntity @relation(fields: [ourLegalEntityId], references: [id], onDelete: Restrict)
  clientId         String
  client           Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  locationId       String
  location         ClientLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)
  deliveryDate     DateTime       @db.Date

  supplierSnapshot Json
  buyerSnapshot    Json
  linesSnapshot    Json

  totalAmount      Decimal  @db.Decimal(12, 2)
  vatRate          Decimal? @db.Decimal(5, 2)
  vatAmount        Decimal? @db.Decimal(12, 2)
  amountWithoutVat Decimal  @db.Decimal(12, 2)

  generatedById String?
  generatedBy   User?    @relation("UpdGeneratedBy", fields: [generatedById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  orders UpdDocumentOrder[]

  @@unique([ourLegalEntityId, clientId, locationId, deliveryDate], name: "upd_business_key")
  @@index([ourLegalEntityId, year])
  @@index([clientId])
  @@index([createdAt])
}

model UpdDocumentOrder {
  id            String      @id @default(cuid())
  updDocumentId String
  updDocument   UpdDocument @relation(fields: [updDocumentId], references: [id], onDelete: Cascade)
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([updDocumentId, orderId])
  @@unique([orderId], name: "one_upd_per_order")
  @@index([orderId])
}

// ============================================================
// INVOICES (Спринт 7.14A)
// Приёмка товарных накладных: фото → Vision → matching ingredients
// → ADMIN_PRO accept/reject → обновление pricePerUnit и history.
// Бизнес-ключ: (supplierName, invoiceNumber, invoiceDate) — защита
// от двойной загрузки одной и той же накладной.
// ============================================================

model Invoice {
  id                String            @id @default(cuid())
  supplierName      String
  // Lower-cased + trimmed копия supplierName для бизнес-ключа и индексов
  // (Postgres collation независимый поиск).
  supplierNameLower String
  // 7.14B-2: ИНН поставщика (10 или 12 цифр) — извлекается Vision-моделью.
  // Опционально; используется для будущего сопоставления поставщиков.
  // VARCHAR(20) синхронизирован с migration.sql — лишний запас на edge-case.
  supplierInn       String?           @db.VarChar(20)
  invoiceNumber     String
  invoiceDate       DateTime
  receivedAt        DateTime          @default(now())
  receivedById      String
  receivedBy        User              @relation("InvoicesReceived", fields: [receivedById], references: [id])
  acceptedById      String?
  acceptedBy        User?             @relation("InvoicesAccepted", fields: [acceptedById], references: [id])
  acceptedAt        DateTime?
  revertedById      String?
  revertedBy        User?             @relation("InvoicesReverted", fields: [revertedById], references: [id])
  revertedAt        DateTime?
  imageUrl          String
  imageWidth        Int?
  imageHeight       Int?
  exifTakenAt       DateTime?
  // Эвристика: EXIF слишком старый/будущий или отсутствует — ставим true,
  // ADMIN_PRO видит предупреждение в UI приёмки.
  exifSuspicious    Boolean           @default(false)
  status            InvoiceStatus
  progress          InvoiceProgress
  // Сырой JSON от Vision-модели — для аудита и пересборки строк.
  aiRawResponse     Json?
  aiErrorMessage    String?
  totalAmount       Decimal?          @db.Decimal(10, 2)
  // Максимальный уровень alert среди строк — для антидубль-чека Telegram-пушей.
  alertLevelSent    PriceChangeLevel?
  lines             InvoiceLine[]

  @@unique([supplierNameLower, invoiceNumber, invoiceDate], name: "invoice_business_key")
  @@index([status, progress])
  @@index([receivedAt])
  @@index([supplierNameLower])
  @@index([supplierInn])
}

model InvoiceLine {
  id                   String             @id @default(cuid())
  invoiceId            String
  invoice              Invoice            @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineIndex            Int
  rawName              String
  rawQuantity          Decimal            @db.Decimal(10, 3)
  rawUnit              String
  rawPricePerUnit      Decimal            @db.Decimal(10, 2)
  rawAmount            Decimal            @db.Decimal(10, 2)
  matchedIngredientId  String?
  matchedIngredient    Ingredient?        @relation(fields: [matchedIngredientId], references: [id])
  matchedAction        InvoiceMatchAction
  aiConfidence         InvoiceConfidence
  aiContext            String?
  // Цена за кг/л, нормализованная из rawUnit (для сравнения с предыдущей).
  pricePerKgNormalized Decimal?           @db.Decimal(10, 2)
  previousPricePerKg   Decimal?           @db.Decimal(10, 2)
  priceChangePercent   Decimal?           @db.Decimal(6, 2)
  priceChangeLevel     PriceChangeLevel
  // Координаты bounding box на исходном фото — для подсветки в UI.
  boundingBoxes        Json?

  @@index([invoiceId, lineIndex])
  @@index([matchedIngredientId])
}

// ============================================================
// TONE ALERTS (Спринт 7.15) — лог отправленных tone-алёртов
// (rude/urgent) менеджерам в Telegram. Используется для cooldown
// в notifyToneAlert (15 мин на пару clientId+tone для rude;
// urgent игнорирует cooldown).
// ============================================================

model ToneAlertLog {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tone      String // 'rude' | 'urgent'
  createdAt DateTime @default(now())

  @@index([clientId, tone, createdAt])
}

// ============================================================
// CLIENT ALERTS (Спринт 7.15.B) — единый лог Telegram-алёртов
// о клиентах. Заменяет split logic между ToneAlertLog (7.15) и
// InboxItem.lastPushedAt (5.x). Per-client 2-мин cooldown с
// escalation rule (urgent прорывается через rude-cooldown).
// ============================================================

model ClientAlertLog {
  id          String     @id @default(cuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  inboxItemId String?
  inboxItem   InboxItem? @relation(fields: [inboxItemId], references: [id], onDelete: SetNull)
  tone        String? // 'rude' | 'urgent' | null
  reason      String? // InboxItemReason value | null
  priority    String? // 'HIGH' | 'NORMAL' | null
  createdAt   DateTime   @default(now())

  @@index([clientId, createdAt])
}

# === Required for production ===
# PostgreSQL connection (Neon recommended)
# Get from Neon dashboard → your branch → Connection Details → Pooled connection
DATABASE_URL="postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Same database, but DIRECT connection (without -pooler in host)
# Used by Prisma migrations
DIRECT_URL="postgres://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# JWT secret for session signing
# Generate: openssl rand -base64 32
JWT_SECRET="your-32-byte-base64-secret-here"
# Cron secret — protects /api/cron/* endpoints
# Generate: openssl rand -hex 32
CRON_SECRET="your-64-char-hex-secret-here"
# === Optional for now ===
# Anthropic Claude API key — for AI features (Sprint 5+)
ANTHROPIC_API_KEY=""
# MAX bot token — for messaging integration (Sprint 5+)
# Get from business.max.ru/self → Чат-боты → Интеграция → Получить токен
MAX_BOT_TOKEN=""

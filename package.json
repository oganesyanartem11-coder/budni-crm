  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:reset": "dotenv -e .env.local -- prisma migrate reset",
    "db:check": "dotenv -e .env.local -- tsx prisma/check-connection.ts",
    "db:seed:users": "dotenv -e .env.local -- tsx prisma/seed-users.ts",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed/index.ts"
  },
